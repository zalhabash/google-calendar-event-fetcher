{
  "name": "google-calendar-event-fetcher",
  "version": "0.2.0",
  "description": "Fetch and transform events from the Google Calendar API",
  "keywords": [
    "calendar",
    "fullcalendar",
    "google",
    "google-calendar"
  ],
  "homepage": "https://github.com/nstringham/google-calendar-event-fetcher#readme",
  "bugs": {
    "url": "https://github.com/nstringham/google-calendar-event-fetcher/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Nate Stringham",
    "url": "https://github.com/nstringham"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nstringham/google-calendar-event-fetcher.git"
  },
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./range-set": {
      "types": "./lib/range-set.d.ts",
      "default": "./lib/range-set.js"
    },
    "./fullcalendar": {
      "types": "./lib/fullcalendar/index.d.ts",
      "default": "./lib/fullcalendar/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:browser": "vitest run --browser",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "version": "version-changelog CHANGELOG.md && git add CHANGELOG.md",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.17",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^6.0.2",
    "version-changelog": "^3.1.1",
    "vitest": "^4.0.17"
  },
  "peerDependencies": {
    "@fullcalendar/core": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@fullcalendar/core": {
      "optional": true
    }
  }
}
